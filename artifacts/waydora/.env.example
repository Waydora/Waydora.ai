# Waydora webapp — variabili d'ambiente (Vite). Copia in `.env` e compila.
# NOTA: solo le variabili con prefisso VITE_ sono esposte al client.

# ── Supabase (richiesto) ────────────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Backend / chat AI ────────────────────────────────────────────────────────
VITE_API_URL=
VITE_CHAT_URL=

# ── Integrazioni opzionali ────────────────────────────────────────────────────
VITE_GOOGLE_MAPS_KEY=
VITE_WEATHER_API_KEY=
VITE_PEXELS_API_KEY=
VITE_TELEGRAM_BOT_URL=
VITE_TELEGRAM_BOT_USERNAME=

# ── Analytics: PostHog (opzionale) ───────────────────────────────────────────
# Se VITE_POSTHOG_KEY è ASSENTE, il tracking è un NO-OP totale: nessun init,
# nessuna chiamata di rete, nessun errore. Il codice resta deployabile e il
# tracking si attiva solo aggiungendo la chiave qui.
# Anche con la chiave, gli eventi partono solo dopo il consenso esplicito
# dell'utente (banner GDPR opt-in, vedi src/lib/analytics.ts).
VITE_POSTHOG_KEY=
# Host EU di default (consigliato per GDPR Italia/EU). Se vuoto → eu.i.posthog.com
VITE_POSTHOG_HOST=https://eu.i.posthog.com
